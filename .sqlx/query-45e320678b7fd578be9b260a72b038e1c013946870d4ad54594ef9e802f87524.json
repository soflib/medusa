{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT\n                    id, actor_id, actor_email,\n                    action         AS \"action: _\",\n                    target_user_id, sign_doc_id, token_id, key_id,\n                    ip_address     AS \"ip_address: _\",\n                    user_agent,\n                    metadata       AS \"metadata: _\",\n                    success, error_message, created_at\n                FROM auth.history\n                WHERE success = FALSE\n                  AND action  = $1\n                ORDER BY created_at DESC\n                LIMIT $2\n                ",
