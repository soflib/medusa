  "query": "\n            SELECT id, name,\n                   status AS \"status: _\",\n                   privat_db, payment_id,\n                   created_at, updated_at, deleted_at\n            FROM auth.tenants\n            WHERE deleted_at IS NULL\n            ORDER BY created_at DESC\n            LIMIT $1 OFFSET $2\n            ",
