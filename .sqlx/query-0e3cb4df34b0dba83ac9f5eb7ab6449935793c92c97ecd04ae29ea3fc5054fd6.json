  "query": "\n            UPDATE auth.tenants SET\n                name   = COALESCE($2, name),\n                status = COALESCE($3, status)\n            WHERE id = $1 AND deleted_at IS NULL\n            RETURNING\n                id, name,\n                status AS \"status: _\",\n                privat_db, payment_id,\n                created_at, updated_at, deleted_at\n            ",
